#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_CONFIG="${WECLAW_CONFIG:-$HOME/.weclaw/services.json}"

find_guardian_bin() {
  local candidates=(
    "$SCRIPT_DIR/weclaw-guardian"
    "$HOME/.weclaw/bin/weclaw-guardian"
    "$HOME/.longclaw/runtime-v2/bin/weclaw-guardian"
  )

  local candidate
  for candidate in "${candidates[@]}"; do
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

if ! GUARDIAN_BIN="$(find_guardian_bin)"; then
  cat >&2 <<'ERR'
weclaw-guardian binary not found.
Build it from your longclaw-agent-os repository:
  bash scripts/guardian/build-core.sh
ERR
  exit 1
fi

run_with_retry() {
  local attempts="$1"
  shift

  local attempt output status
  for ((attempt = 1; attempt <= attempts; attempt++)); do
    output="$("$@" 2>&1)" && {
      [[ -n "$output" ]] && printf '%s\n' "$output"
      return 0
    }
    status=$?
    if [[ "$output" != *"unexpected end of JSON input"* ]]; then
      [[ -n "$output" ]] && printf '%s\n' "$output" >&2
      return "$status"
    fi
    if (( attempt < attempts )); then
      sleep 0.1
    fi
  done

  [[ -n "$output" ]] && printf '%s\n' "$output" >&2
  return "$status"
}

cmd="${1:-reconcile}"
shift || true

case "$cmd" in
  reconcile)
    run_with_retry 3 "$GUARDIAN_BIN" failover reconcile --config "$DEFAULT_CONFIG" "$@"
    exit $?
    ;;
  status)
    run_with_retry 3 "$GUARDIAN_BIN" failover status --config "$DEFAULT_CONFIG" "$@"
    exit $?
    ;;
  active-agent)
    run_with_retry 3 "$GUARDIAN_BIN" active-agent --config "$DEFAULT_CONFIG" "$@"
    exit $?
    ;;
  switch)
    run_with_retry 3 "$GUARDIAN_BIN" failover switch --config "$DEFAULT_CONFIG" "$@"
    exit $?
    ;;
  *)
    cat >&2 <<'ERR'
usage: routing-controller [reconcile|status|active-agent|switch] [args...]
ERR
    exit 2
    ;;
esac
