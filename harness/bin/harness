}

function sendProgressBrief(summary) {
  if (PLAN_ONLY_MODE) {
    return {
      status: "pass",
      channel: "dashboard_only",
      failures: [],
      nextActions: ["当前运行在 plan-only 模式，进度播报仅保留在本地 dashboard 和 outbox。"],
    };
  }
  const target = discoverWeclawNotificationTarget();
  if (!target) {
    return {
      status: "held",
      channel: "local_only",
      failures: ["没有发现可用的 weclaw 目标账号。"],
      nextActions: ["没有可用的 weclaw 账户，进度播报只写入本地 outbox。"],
    };
  }
  const bin = resolveWeclawBin();
  if (!bin) {
    return {
      status: "held",
      channel: "local_only",
      failures: ["weclaw 二进制不可用。"],
      nextActions: ["weclaw 不可用，进度播报只写入本地 outbox。"],
    };
  }
  if (!lookupWeclawContextToken(target)) {
    return {
      status: "held",
      channel: "local_only",
      failures: [`还没有 ${target} 的可用微信回复上下文。`],
      nextActions: ["先从微信给 bot 发一条任意消息，建立新的 reply context 后，harness 会自动继续播报。"],
    };
  }
  ensureWeclawRunning(bin);
  const text = [
    "🧭 Harness 管理汇报",
    "━━━━━━━━━━━━━━━━━━━━",
    "",
    `  · 总体判断：${summary.headline}`,
    `  · 已完成：${summary.completed[0] || "无"}`,
    `  · 最近动作：${summary.recent_actions[0] || "无"}`,
    `  · 正在推进：${summary.current_work}`,
    `  · 风险阻塞：${summary.blockers[0] || "无"}`,
    "",
    "👉 下一步动作",
    `  1. ${summary.next_steps[0] || "继续 loop 并观察新 failure"}`,
    `  2. 查看进度面板：${path.join(dashboardDir, "progress.md")}`,
  ].join("\n");
  const result = runShell(`${shellQuote(bin)} send --to ${shellQuote(target)} --text ${shellQuote(text)}`, repoRoot);
  return {
    status: result.status === 0 ? "pass" : "held",
    channel: result.status === 0 ? "weclaw" : "local_only",
    failures: result.status === 0 ? [] : collectOutput(result),
    nextActions: result.status === 0
      ? ["进度播报已通过 weclaw 发送。"]
      : ["weclaw 发送失败，进度播报保留在本地 outbox。"],
  };
}

function markFailureNotified(failureId, delivered) {
  const db = loadFailures();
  const failure = db.failures.find((item) => item.failure_id === failureId);
  if (!failure) return;
  failure.notified_at = new Date().toISOString();
  failure.notification_delivered = delivered;
  saveFailures(db);
}

function sendViaWeclaw(payload) {
  const target = discoverWeclawNotificationTarget();
  if (!target) {
    return {
      status: "held",
      channel: "local_only",
      failures: ["No usable weclaw notification target was discovered."],
      nextActions: ["Inspect the outbox report or configure a valid weclaw account."],
    };
  }

  const bin = resolveWeclawBin();
  if (!bin) {
    return {
      status: "held",
      channel: "local_only",
      failures: ["weclaw binary is not available."],
      nextActions: ["Inspect the outbox report or restore the canonical weclaw binary."],
    };
  }

  ensureWeclawRunning(bin);
  const text = [
    payload.title,
    "━━━━━━━━━━━━━━━━━━━━",
    "",
    `  · 项目：${payload.project}`,
    `  · Failure：${payload.failure_id}`,
    `  · 分类：${payload.category}`,
    `  · 风险：${payload.risk_level}`,
    `  · 摘要：${payload.summary}`,
    "",
    "👉 建议动作",
    `  1. ${payload.action_label}`,
    `  2. 查看报告：${payload.report_path}`,
  ].join("\n");
  const result = runShell(`${shellQuote(bin)} send --to ${shellQuote(target)} --text ${shellQuote(text)}`, repoRoot);
  if (result.status === 0) {
    return {
      status: "pass",
      channel: "weclaw",
      failures: [],
      nextActions: ["Notification sent through weclaw."],
    };
  }
  return {
    status: "held",
    channel: "local_only",
    failures: collectOutput(result),
    nextActions: ["Weclaw send failed. Check the outbox report and weclaw account state."],
  };
}

function discoverWeclawNotificationTarget() {
  const home = process.env.HOME;
  if (!home) return null;
  const accountsDir = path.join(home, ".weclaw", "accounts");
  if (!fs.existsSync(accountsDir)) return null;
  const files = fs.readdirSync(accountsDir)
    .filter((name) => name.endsWith(".json"))
    .sort();
  for (const name of files) {
    try {
      const payload = JSON.parse(fs.readFileSync(path.join(accountsDir, name), "utf8"));
      if (payload.ilink_user_id) return payload.ilink_user_id;
    } catch {
      continue;
    }
  }
  return null;
}

function resolveWeclawBin() {
  const home = process.env.HOME || "";
  const canonical = path.join(home, ".weclaw", "bin", "weclaw");
  if (fs.existsSync(canonical)) return canonical;
  const probe = spawnSync("bash", ["-lc", "command -v weclaw"], { encoding: "utf8" });
  if (probe.status === 0) return probe.stdout.trim();
  return "";
}

function lookupWeclawContextToken(userId) {
  const home = process.env.HOME || "";
  if (!home || !userId) return "";
  const file = path.join(home, ".weclaw", "runtime", "context_tokens.json");
  if (!fs.existsSync(file)) return "";
  try {
    const payload = JSON.parse(fs.readFileSync(file, "utf8"));
    return payload?.tokens?.[userId]?.context_token || "";
  } catch {
    return "";
  }
}

function ensureWeclawRunning(bin) {
  const status = runShell(`${shellQuote(bin)} status`, repoRoot);
  const output = `${status.stdout || ""}\n${status.stderr || ""}`;
  if (status.status === 0 && /is running/i.test(output)) {
    return;
  }
  runShell(`${shellQuote(bin)} start`, repoRoot);
}

function riskEmoji(riskLevel) {
  switch (riskLevel) {
    case "high":
      return "🚨";
    case "medium":
      return "⚠️";
    default:
      return "📦";
  }
}

function notificationActionLabel(failure) {
  if (riskLevelForCategory(failure.category) === "high") {
    return "请立即确认是否人工接管";
  }
  if (failure.status === "rolled_back") {
    return "自动修复已回滚，请人工检查原因";
  }
  if (failure.status === "held") {
    return "自动流程已暂停，等待人工介入";
  }
  if (failure.status === "autofix_failed") {
    return "自动修复失败，请确认是否继续推进";
  }
  return "请检查当前 failure 并决定是否人工接管";
}

function notificationSummaryLine(failure) {
  const lines = (failure.failures || []).filter(Boolean);
  if (lines.length === 0) {
    return "Harness 检测到需要人工介入的事件。";
  }

  const moduleMissing = lines.find((line) => /ModuleNotFoundError: No module named/.test(line));
  if (moduleMissing) {
    const match = moduleMissing.match(/No module named '([^']+)'/);
    if (match) return `测试环境缺少依赖：${match[1]}`;
  }

  const frontmatterMissing = lines.find((line) => /missing frontmatter/i.test(line));
  if (frontmatterMissing) {
    return `知识库结构不完整：${frontmatterMissing.replace(/^-\s*/, "")}`.slice(0, 120);
  }

  const useful = lines.find((line) =>
    !/^(=+|!+|Traceback:|platform |rootdir:|collected \d+ items|ERROR tests\/|Hint:)/.test(line),
  );
  return (useful || lines[0]).replace(/\s+/g, " ").slice(0, 120);
}

function systemFailureLines(failure, fallback = []) {
  if (failure) {
    return [
      `${failure.project}/${failure.category}: ${notificationSummaryLine(failure)}`,
      `Failure status: ${failure.status}`,
    ];
  }
  return fallback.length > 0 ? fallback.slice(0, 3) : [];
}

function uniqueLines(items) {
  return [...new Set((items || []).filter(Boolean))];
}

function loadActivity() {
  if (!fs.existsSync(activityFile)) {
    return { entries: [] };
  }
  return normalizeActivityDb(JSON.parse(fs.readFileSync(activityFile, "utf8")));
}

function saveActivity(db) {
  fs.writeFileSync(activityFile, JSON.stringify(normalizeActivityDb(db), null, 2) + "\n", "utf8");
}

function normalizeActivityDb(db) {
  const ordered = (db.entries || [])
    .filter((item) => item && item.timestamp && item.summary)
    .sort((a, b) => Date.parse(a.timestamp || 0) - Date.parse(b.timestamp || 0))
    .slice(-200);
  const entries = [];
  for (const item of ordered) {
    const last = entries[entries.length - 1];
    if (
      last &&
      last.summary === item.summary &&
      last.project === item.project &&
      last.workflow === item.workflow
    ) {
      entries[entries.length - 1] = item;
      continue;
    }
    entries.push(item);
  }
  return { entries };
}

function shouldRecordActivity(payload) {
  if (payload.project !== "system") return true;
  if (payload.workflow !== "tick") return true;
  const meaningfulChecks = (payload.checks || []).filter((item) => item !== "Progress summary: pass");
  return payload.status !== "pass" || payload.failures.length > 0 || meaningfulChecks.length > 0;
}

function activitySummaryForPayload(payload) {
  const label = payload.project === "system" ? "system" : payload.project;
  if (payload.workflow === "brief") {
    return `${label} · 管理汇报已刷新 (${payload.status})`;
  }
  if (payload.workflow === "notify") {
    return `${label} · 已发送介入通知 (${payload.status})`;
  }
  if (payload.workflow === "tick") {
    return `${label} · loop 执行一轮 (${payload.status})`;
  }
  if (payload.workflow === "eval" && payload.status === "pass") {
    return `${label} · 完成健康检查并通过`;
  }
  if (payload.workflow === "doctor" && payload.status === "pass") {
    return `${label} · 完成环境体检并通过`;
  }
  return `${label} · ${payload.workflow} · ${payload.status}`;
}

function recordActivity(payload, reportPath) {
  if (!shouldRecordActivity(payload)) return;
  const db = loadActivity();
  const entry = {
    timestamp: payload.timestamp,
    project: payload.project,
    workflow: payload.workflow,
    status: payload.status,
    risk_level: payload.risk_level || null,
    failure_id: payload.failure_id || null,
    report_path: reportPath || null,
    summary: activitySummaryForPayload(payload),
  };
  const last = db.entries[db.entries.length - 1];
  if (
    last &&
    last.summary === entry.summary &&
    last.project === entry.project &&
    last.workflow === entry.workflow &&
    Math.abs(Date.parse(entry.timestamp) - Date.parse(last.timestamp)) < 60_000
  ) {
    db.entries[db.entries.length - 1] = entry;
  } else {
    db.entries.push(entry);
  }
  saveActivity(db);
}

function formatUiTimestamp(timestamp) {
  if (!timestamp) return "";
  return new Date(timestamp).toLocaleString("zh-CN", {
    month: "2-digit",
    day: "2-digit",
    hour: "2-digit",
    minute: "2-digit",
    hour12: false,
  });
}

function recentActivityLines(limit = 8) {
  return loadActivity().entries
    .slice(-limit)
    .reverse()
    .map((entry) => `${formatUiTimestamp(entry.timestamp)} · ${entry.summary}`);
}

function mergeTickStatus(current, next) {
  const rank = {
    pass: 0,
    partial: 1,
    autofix_planned: 1,
    autofix_running: 1,
    not_checked: 1,
    autofix_pass: 1,
    held: 2,
    rolled_back: 2,
    fail: 3,
    autofix_failed: 3,
  };
  return (rank[next] || 0) > (rank[current] || 0) ? next : current;
}

function latestActiveFailure(projectId) {
  const db = loadFailures();
  return db.failures
    .filter((item) => item.project === projectId)
    .filter((item) => !["autofix_pass", "resolved"].includes(item.status))
    .sort((a, b) => Date.parse(b.last_seen_at) - Date.parse(a.last_seen_at))[0] || null;
}

function loadFailures() {
  if (!fs.existsSync(failuresFile)) {
    return { failures: [] };
  }
  return normalizeFailuresDb(JSON.parse(fs.readFileSync(failuresFile, "utf8")));
}

function saveFailures(db) {
  fs.writeFileSync(failuresFile, JSON.stringify(normalizeFailuresDb(db), null, 2) + "\n", "utf8");
}

function normalizeFailuresDb(db) {
  for (const failure of db.failures || []) {
    if (!failure.category) continue;
    failure.risk_level = riskLevelForCategory(failure.category);
    failure.next_allowed_action = nextAllowedActionForStatus(failure.status, failure.category);
  }
  return db;
}

function resolveProjectFailures(projectId, timestamp = new Date().toISOString()) {
  const db = loadFailures();
  let changed = false;
  for (const failure of db.failures || []) {
    if (failure.project !== projectId) continue;
    if (failure.status === "resolved") continue;
    failure.status = "resolved";
    failure.last_seen_at = timestamp;
    failure.resolved_at = timestamp;
    failure.next_allowed_action = "none";
    changed = true;
  }
  if (changed) saveFailures(db);
}

function upsertFailureRecord(project, payload) {
  if (!payload.category || !["fail", "partial"].includes(payload.status)) {
    return null;
  }

  const signatureBase = [
    project.id,
    payload.workflow,
    payload.category,
    ...(payload.failures || []).slice(0, 5),
  ].join("\n");
  const signature = hashText(signatureBase);
  const failureId = `${project.id}-${payload.category}-${signature.slice(0, 10)}`;
  const timestamp = payload.timestamp;
  const db = loadFailures();
  const existing = db.failures.find((item) => item.failure_id === failureId);

  if (existing) {
    existing.last_seen_at = timestamp;
    existing.status = payload.status;
    existing.attempt_count = existing.attempt_count || 0;
    existing.risk_level = riskLevelForCategory(payload.category);
    existing.next_allowed_action = nextAllowedActionForStatus(payload.status, payload.category);
    existing.failures = payload.failures;
    existing.checks = payload.checks;
    saveFailures(db);
    return failureId;
  }

  db.failures.push({
    failure_id: failureId,
    project: project.id,
    workflow: payload.workflow,
    category: payload.category,
    signature,
    first_seen_at: timestamp,
    last_seen_at: timestamp,
    attempt_count: 0,
    status: payload.status,
    risk_level: riskLevelForCategory(payload.category),
    next_allowed_action: nextAllowedActionForStatus(payload.status, payload.category),
    failures: payload.failures,
    checks: payload.checks,
  });
  saveFailures(db);
  return failureId;
}

function updateFailureStatus(failureId, status) {
  const db = loadFailures();
  const failure = db.failures.find((item) => item.failure_id === failureId);
  if (!failure) return;
  failure.status = status;
  failure.last_seen_at = new Date().toISOString();
  failure.risk_level = riskLevelForCategory(failure.category);
  failure.next_allowed_action = nextAllowedActionForStatus(status, failure.category);
  if (["autofix_running", "autofix_failed", "autofix_pass", "rolled_back", "held"].includes(status)) {
    failure.attempt_count = (failure.attempt_count || 0) + (status === "autofix_running" ? 1 : 0);
  }
  saveFailures(db);
}

function persistWorkflowResult(project, result) {
  const timestamp = new Date().toISOString();
  const payload = {
    project: project.id,
    name: project.name,
    workflow: result.workflow,
    status: result.status,
    timestamp,
    checks: result.checks || [],
    failures: result.failures || [],
    nextActions: result.nextActions || [],
    category: result.category || null,
    risk_level: result.category ? riskLevelForCategory(result.category) : null,
    failure_id: result.failureId || null,
    details: result.details || {},
  };

  if (!payload.failure_id) {
    payload.failure_id = upsertFailureRecord(project, payload);
  }

  if (payload.workflow === "eval" && payload.status === "pass") {
    resolveProjectFailures(project.id, timestamp);
  }

  const reportName = result.reportName || "latest";
  ensureDir(path.join(generatedRoot, project.id));
  fs.writeFileSync(latestMarkdownPath(project.id, reportName), renderReport(payload), "utf8");
  fs.writeFileSync(latestJsonPath(project.id, reportName), JSON.stringify(payload, null, 2) + "\n", "utf8");
  recordActivity(payload, latestMarkdownPath(project.id, reportName));
  updateDashboardSummary(loadProjects());

  return {
    ...payload,
    project,
    reportPath: latestMarkdownPath(project.id, reportName),
  };
}

function migrateLegacyHarnessRuntime() {
  ensureDir(stateRoot);
  ensureDir(generatedRoot);

  const legacyStateFiles = ["failures.json", "schedule.json", "notifications.json", "activity.json"];
  for (const name of legacyStateFiles) {
    const legacy = path.join(legacyStateRoot, name);
    const current = path.join(stateRoot, name);
    if (!fs.existsSync(current) && fs.existsSync(legacy)) {
      fs.copyFileSync(legacy, current);
    }
  }

  if (!fs.existsSync(path.join(generatedRoot, "system")) && fs.existsSync(legacyGeneratedRoot)) {
    copyDirectory(legacyGeneratedRoot, generatedRoot);
  }
}

function copyDirectory(sourceDir, targetDir) {
  ensureDir(targetDir);
  for (const entry of fs.readdirSync(sourceDir, { withFileTypes: true })) {
    const source = path.join(sourceDir, entry.name);
    const target = path.join(targetDir, entry.name);
    if (entry.isDirectory()) {
      copyDirectory(source, target);
    } else if (!fs.existsSync(target)) {
      fs.copyFileSync(source, target);
    }
  }
}

function persistSystemReport(reportName, result) {
  const timestamp = new Date().toISOString();
  const payload = {
    project: "system",
    name: "Harness System",
    workflow: result.workflow,
    status: result.status,
    timestamp,
    checks: result.checks || [],
    failures: result.failures || [],
    nextActions: result.nextActions || [],
    category: result.category || null,
    risk_level: result.category ? riskLevelForCategory(result.category) : null,
    failure_id: result.failureId || null,
    details: result.details || {},
  };
  ensureDir(path.join(generatedRoot, "system"));
  fs.writeFileSync(latestMarkdownPath("system", reportName), renderReport(payload), "utf8");
  fs.writeFileSync(latestJsonPath("system", reportName), JSON.stringify(payload, null, 2) + "\n", "utf8");
  recordActivity(payload, latestMarkdownPath("system", reportName));
  updateDashboardSummary(loadProjects());
  return {
    ...payload,
    project: { id: "system" },
    reportPath: latestMarkdownPath("system", reportName),
  };
}

function renderReport(payload) {
  const lines = [
    `# ${payload.name} ${payload.workflow} report`,
    "",
    `- Project: ${payload.project}`,
    `- Workflow: ${payload.workflow}`,
    `- Status: ${payload.status}`,
    `- Timestamp: ${payload.timestamp}`,
  ];
  if (payload.category) lines.push(`- Category: ${payload.category}`);
  if (payload.risk_level) lines.push(`- Risk Level: ${payload.risk_level}`);
  if (payload.failure_id) lines.push(`- Failure ID: ${payload.failure_id}`);
  lines.push("", "## Checks", "", ...renderBullets(payload.checks), "", "## Failures", "", ...renderBullets(payload.failures), "", "## Next Actions", "", ...renderBullets(payload.nextActions));
  if (payload.details && Object.keys(payload.details).length > 0) {
    lines.push("", "## Details", "");
    for (const [key, value] of Object.entries(payload.details)) {
      lines.push(`- ${key}: ${Array.isArray(value) ? value.join(", ") : String(value)}`);
    }
  }
  lines.push("");
  return lines.join("\n");
}

function renderBullets(items) {
  return items.length > 0 ? items.map((item) => `- ${item}`) : ["- None"];
}

function printResultSummary(result) {
  console.log(`${result.project.id}: ${result.status} (${result.workflow})`);
  console.log(`report: ${result.reportPath}`);
}

function latestMarkdownPath(projectId, reportName) {
  return path.join(generatedRoot, projectId, `${reportName}.md`);
}

function latestJsonPath(projectId, reportName) {
  return path.join(generatedRoot, projectId, `${reportName}.json`);
}

function updateDashboardSummary(projects) {
  updateNotificationDashboard();
  const rows = [];
  for (const project of projects) {
    const payload = latestPayloadForProject(project.id);
    if (!payload) continue;
    rows.push(`${project.id}: ${payload.status} (${payload.workflow}) at ${payload.timestamp}`);
  }
  const activeFailureIds = new Set(
    loadFailures().failures
      .filter((item) => !["resolved", "autofix_pass"].includes(item.status))
      .map((item) => item.failure_id),
  );
  const notifications = loadNotifications().notifications
    .filter((item) => activeFailureIds.has(item.failure_id))
    .slice(-5)
    .reverse()
    .map((item) => `${riskEmoji(item.risk_level || "low")} ${item.project}: ${item.summary}`);
  const activity = recentActivityLines(6);
  fs.writeFileSync(
    path.join(dashboardDir, "latest.md"),
    [
      "# Harness Dashboard",
      "",
      "## Projects",
      "",
      ...renderBullets(rows),
      "",
      "## Recent Actions",
      "",
      ...renderBullets(activity),
      "",
      "## Active Notifications",
      "",
      ...(notifications.length > 0
        ? renderBullets(notifications)
        : ["- No active intervention notifications. Historical alerts have been archived."]),
      "",
    ].join("\n"),
    "utf8",
  );
}

function latestPayloadForProject(projectId) {
  const candidates = ["latest", "autofix-latest", "fix-plan-latest", "hold-latest"]
    .map((name) => latestJsonPath(projectId, name))
    .filter((file) => fs.existsSync(file))
    .map((file) => ({ file, mtime: fs.statSync(file).mtimeMs }))
    .sort((a, b) => b.mtime - a.mtime);
  if (candidates.length === 0) return null;
  return JSON.parse(fs.readFileSync(candidates[0].file, "utf8"));
}

function commandExists(command) {
  return spawnSync("bash", ["-lc", `command -v ${shellQuote(command)}`], { encoding: "utf8" }).status === 0;
}

function launchctlHasLabel(label) {
  return runShell(`launchctl print gui/$(id -u)/${shellQuote(label)}`, repoRoot).status === 0;
}

function runShell(command, cwd, options = {}) {
  return spawnSync("bash", ["-lc", command], {
    cwd,
    encoding: "utf8",
    maxBuffer: 20 * 1024 * 1024,
    timeout: options.timeoutMs || 0,
  });
}

function detectMissingModule(lines) {
  const text = Array.isArray(lines) ? lines.join("\n") : String(lines || "");
  const match = text.match(/No module named '([^']+)'/);
  return match ? match[1] : null;
}

function specsForMissingModule(moduleName) {
  if (!moduleName) return [];
  if (moduleName === "fastapi" || moduleName === "starlette" || moduleName === "httpx") {
    return [...SIGNALS_BASE_DEPENDENCIES];
  }
  return SIGNALS_OPTIONAL_DEPENDENCIES[moduleName] || [];
}

function uniquePackageSpecs(specs) {
  return [...new Set(specs.filter(Boolean))];
}

function buildSignalsDependencyPlan(failure, requirementsFile) {
  const missingModule = detectMissingModule(failure.failures || []);
  const plan = [...SIGNALS_BASE_DEPENDENCIES, ...specsForMissingModule(missingModule)];
  if (!missingModule && failure.category === "dependency_missing" && fs.existsSync(requirementsFile)) {
    const requirementLines = fs.readFileSync(requirementsFile, "utf8")
      .split(/\r?\n/)
      .map((line) => line.trim())
      .filter(Boolean)
      .filter((line) => !line.startsWith("#"))
      .filter((line) => line !== "ib_async");
    plan.push(...requirementLines.slice(0, 12));
  }
  return uniquePackageSpecs(plan);
}

function firstNonEmptyLine(text) {
  return text.split(/\r?\n/).map((line) => line.trim()).find(Boolean);
}

function collectOutput(result) {
  return `${result.stdout || ""}\n${result.stderr || ""}`
    .split(/\r?\n/)
    .map((line) => line.trim())
    .filter(Boolean)
    .slice(0, 30);
}

function snapshotFiles(projectId, files) {
  const timestamp = new Date().toISOString().replace(/[:.]/g, "-");
  const snapshotDir = path.join(snapshotRoot, projectId, timestamp);
  ensureDir(snapshotDir);
  const manifest = [];
  for (const file of files) {
    const source = path.resolve(file);
    const relative = source.replace(/^\//, "");
    const backup = path.join(snapshotDir, relative);
    ensureDir(path.dirname(backup));
    if (fs.existsSync(source)) {
      fs.copyFileSync(source, backup);
      manifest.push({ source, backup, existed: true });
    } else {
      manifest.push({ source, backup, existed: false });
    }
  }
  fs.writeFileSync(path.join(snapshotDir, "manifest.json"), JSON.stringify(manifest, null, 2) + "\n", "utf8");
  return { snapshotDir, manifest };
}

function restoreSnapshot(snapshot) {
  for (const entry of snapshot.manifest) {
    if (entry.existed) {
      ensureDir(path.dirname(entry.source));
      fs.copyFileSync(entry.backup, entry.source);
    } else if (fs.existsSync(entry.source)) {
      fs.rmSync(entry.source);
    }
  }
}

function ensureDir(dir) {
  fs.mkdirSync(dir, { recursive: true });
}

function hashText(value) {
  return crypto.createHash("sha256").update(value).digest("hex");
}

function shellQuote(value) {
  return `'${String(value).replace(/'/g, `'\\''`)}'`;
}
